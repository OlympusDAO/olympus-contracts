{
  "name": "olympus-contracts",
  "version": "1.0.0",
  "description": "Smart Contracts for Olympus",
  "directories": {
    "test": "test"
  },
  "devDependencies": {
    "@defi-wonderland/smock": "^2.0.7",
    "@nomiclabs/hardhat-ethers": "2.0.4",
    "@nomiclabs/hardhat-etherscan": "^3.1.8",
    "@nomiclabs/hardhat-waffle": "^2.0.6",
    "@openzeppelin/contracts": "^4.4.2",
    "@openzeppelin/contracts-upgradeable": "^3.4.2",
    "@openzeppelin/hardhat-upgrades": "^1.12.0",
    "@rari-capital/solmate": "^6.2.0",
    "@typechain/ethers-v5": "^10.2.1",
    "@typechain/hardhat": "^6.1.6",
    "@types/chai": "^4.2.22",
    "@types/mocha": "^9.0.0",
    "@types/node": "^16.10.2",
    "@typescript-eslint/eslint-plugin": "^4.32.0",
    "@typescript-eslint/parser": "^4.32.0",
    "chai": "^4.2.0",
    "chai-ethers": "^0.0.1",
    "dotenv": "^10.0.0",
    "eslint": "^7.32.0",
    "eslint-config-prettier": "^8.3.0",
    "ethereum-waffle": "^4.0.10",
    "ethers": "^5.4.7",
    "hardhat": "^2.23.0",
    "hardhat-deploy": "^1.0.2",
    "hardhat-gas-reporter": "^1.0.4",
    "husky": "^7.0.4",
    "prettier": "^2.4.1",
    "prettier-plugin-solidity": "^1.0.0-beta.18",
    "solhint": "^3.3.6",
    "solhint-plugin-prettier": "^0.0.5",
    "solidity-coverage": "^0.7.17",
    "ts-generator": "^0.1.1",
    "ts-node": "^10.2.1",
    "typechain": "^8.3.2",
    "typescript": "^4.4.3"
  },
  "scripts": {
    "lint": "eslint \"**/*.{js,ts}\" && solhint src/**/*.sol",
    "lint:fix": "eslint --fix \"**/*.{js,ts}\" && solhint --fix src/**/*.sol",
    "lint:sol": "solhint -f table contracts/**/*.sol",
    "format": "prettier --check \"**/*.{ts,js,sol}\" --plugin=prettier-plugin-solidity",
    "format:fix": "prettier --write \"**/*.{ts,js,sol}\" --plugin=prettier-plugin-solidity",
    "compile": "hardhat compile",
    "clean": "hardhat clean",
    "void:deploy": "hardhat deploy",
    "test": "hardhat test",
    "gas": "REPORT_GAS=true hardhat test",
    "coverage": "HARDHAT_DEPLOY_FIXTURE=true hardhat coverage",
    "typechain": "TS_NODE_TRANSPILE_ONLY=true hardhat typechain",
    "fork": "hardhat node",
    "deploy:mainnet": "hardhat --network mainnet deploy",
    "deploy:rinkeby": "hardhat --network rinkeby deploy",
    "deploy:ropsten": "hardhat --network ropsten deploy",
    "deploy:hardhat": "hardhat --network hardhat deploy",
    "deploy:sepolia": "hardhat --network sepolia deploy",
    "sourcify:mainnet": "hardhat --network mainnet sourcify",
    "sourcify:rinkeby": "hardhat --network rinkeby sourcify",
    "etherscan:mainnet": "hardhat --network mainnet etherscan-verify",
    "etherscan:rinkeby": "hardhat --network rinkeby etherscan-verify",
    "etherscan:sepolia": "hardhat --network sepolia etherscan-verify",
    "prestart": "pnpm run typechain",
    "start": "hardhat node --network hardhat",
    "preinstall": "npx only-allow@1.2.2 pnpm",
    "build": "pnpm run compile"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/OlympusDAO/olympus-contracts.git"
  },
  "author": "",
  "bugs": {
    "url": "https://github.com/OlympusDAO/olympus-contracts/issues"
  },
  "homepage": "https://github.com/OlympusDAO/olympus-contracts#readme",
  "engines": {
    "node": ">=22",
    "pnpm": ">=10.33.0",
    "npm": "use-pnpm",
    "yarn": "use-pnpm"
  },
  "pnpm": {
    "overrides": {
      "ajv": "^8.18.0",
      "ansi-regex": "^4.1.1",
      "async": "^2.6.4",
      "axios": "^1.15.2",
      "babel-traverse": "6.26.0",
      "base-x": "^3.0.11",
      "bn.js": "^5.2.3",
      "body-parser": "^1.20.3",
      "brace-expansion": "^2.0.3",
      "braces": "^3.0.3",
      "browserify-sign": "^4.2.2",
      "cipher-base": "^1.0.5",
      "cookie@<0.7.0": "^0.7.0",
      "cookiejar": "^2.1.4",
      "cross-spawn": "^7.0.5",
      "debug@>=3.2.0 <3.2.7": "^3.2.7",
      "decode-uri-component": "^0.2.1",
      "diff": "5.2.2",
      "elliptic": "^6.6.1",
      "es5-ext@>=0.10.0 <0.10.63": "^0.10.63",
      "express": "^4.19.2",
      "fast-uri": "^3.1.2",
      "flatted": "^3.4.2",
      "follow-redirects": "^1.16.0",
      "form-data": "^4.0.4",
      "get-func-name": "^2.0.1",
      "got": "^11.8.5",
      "handlebars": "^4.7.9",
      "http-cache-semantics": "^4.1.1",
      "immutable": "^4.3.8",
      "js-yaml": "^4.1.1",
      "json-schema": "^0.4.0",
      "json5": "^1.0.2",
      "lodash": "^4.18.0",
      "marked": "^4.0.10",
      "micromatch": "^4.0.8",
      "min-document@<=2.19.0": "^2.19.1",
      "minimatch": "^5.1.8",
      "minimist": "^1.2.6",
      "node-fetch": "^2.6.7",
      "path-to-regexp": "^0.1.13",
      "pbkdf2": "^3.1.3",
      "picomatch": "^4.0.4",
      "qs": "^6.14.1",
      "request": "npm:@cypress/request@3.0.10",
      "secp256k1": "^4.0.4",
      "semver": "^7.5.2",
      "send@<0.19.0": "^0.19.0",
      "serialize-javascript": "^7.0.5",
      "serve-static@<1.16.0": "^1.16.0",
      "sha.js": "^2.4.12",
      "shelljs": "^0.8.5",
      "simple-get": "^2.8.2",
      "tar": "^7.5.11",
      "tmp@<=0.2.3": "^0.2.4",
      "tough-cookie": "^4.1.3",
      "underscore": "^1.13.8",
      "undici": "6.24.0",
      "word-wrap": "^1.2.4",
      "ws": "^7.5.10",
      "yargs-parser": "^5.0.1"
    }
  }
}
